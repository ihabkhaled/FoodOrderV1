# Leave all Firebase values empty to use the fully functional local-device mode.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# App configuration
VITE_APP_NAME=FoodOrder

# Initial defaults only — locale and currency are runtime settings in code
# (src/state/deviceConfig.ts); users change them anytime from Settings.
VITE_DEFAULT_LOCALE=en
VITE_DEFAULT_CURRENCY=EGP

# Set to true to force local-device mode even when Firebase values exist (used by E2E).
VITE_FORCE_LOCAL_MODE=
