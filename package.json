{
  "name": "food-order-v1",
  "version": "1.1.1",
  "private": true,
  "type": "module",
  "description": "A mobile-first Capacitor application for reusable food buckets and order tracking.",
  "packageManager": "npm@11.6.0",
  "engines": {
    "node": ">=26.0.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "node node_modules/typescript7/bin/tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "node node_modules/typescript7/bin/tsc -b --pretty false",
    "typecheck:tsc": "tsc -b --pretty false",
    "lint": "eslint . --max-warnings 0",
    "format": "node scripts/check-format.mjs --write",
    "format:check": "node scripts/check-format.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "validate": "npm run knowledge:validate && npm run typecheck && npm run lint && npm run test && npm run build",
    "cap:sync": "npm run build && cap sync",
    "cap:add:android": "cap add android",
    "cap:add:ios": "cap add ios",
    "cap:open:android": "cap open android",
    "cap:open:ios": "cap open ios",
    "cap:run:android": "npm run cap:sync && cap run android",
    "cap:run:ios": "npm run cap:sync && cap run ios",
    "migrate:legacy": "node scripts/migrate-legacy-data.mjs",
    "release:patch": "node tools/release/bump-version.mjs patch",
    "release:minor": "node tools/release/bump-version.mjs minor",
    "release:major": "node tools/release/bump-version.mjs major",
    "knowledge:build": "node scripts/knowledge/cli.mjs build",
    "knowledge:build:incremental": "node scripts/knowledge/cli.mjs build --incremental",
    "knowledge:context": "node scripts/knowledge/cli.mjs context",
    "knowledge:classify": "node scripts/knowledge/cli.mjs classify",
    "knowledge:validate": "node scripts/knowledge/cli.mjs validate",
    "knowledge:links": "node scripts/knowledge/cli.mjs validate --links-only",
    "knowledge:stale": "node scripts/knowledge/cli.mjs stale",
    "knowledge:contradictions": "node scripts/knowledge/cli.mjs contradictions",
    "knowledge:duplicates": "node scripts/knowledge/cli.mjs duplicates",
    "knowledge:orphans": "node scripts/knowledge/cli.mjs orphans",
    "knowledge:graphs": "node scripts/knowledge/cli.mjs build --graphs-only",
    "knowledge:packs": "node scripts/knowledge/cli.mjs build --packs-only",
    "knowledge:benchmark": "node scripts/knowledge/cli.mjs benchmark",
    "knowledge:report": "node scripts/knowledge/cli.mjs report",
    "knowledge:refresh": "npm run knowledge:build && npm run knowledge:validate"
  },
  "dependencies": {
    "@capacitor/app": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/network": "^8.0.0",
    "@capacitor/preferences": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "firebase": "^12.4.0",
    "lucide-react": "^0.545.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.9.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@eslint/js": "^9.36.0",
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^6.0.0-rc.2",
    "eslint-plugin-react-refresh": "^0.4.22",
    "firebase-admin": "^13.5.0",
    "globals": "^16.4.0",
    "jsdom": "^27.0.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.63.0",
    "typescript7": "npm:typescript@7.0.2",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
  }
}
