# Safe service-worker registration and recovery adapter.
write('src/platform/browser/service-worker.adapter.ts', """import { env, isProdBuild } from '../environment';

export const registerServiceWorker = async (): Promise<void> => {
  if (!('serviceWorker' in navigator) || !isProdBuild) return;

  const serviceWorkerUrl = `/sw.js?v=${encodeURIComponent(env.appVersion)}`;
  const registration = await navigator.serviceWorker
    .register(serviceWorkerUrl, { updateViaCache: 'none' })
    .catch(() => null);
  if (!registration) return;
  await registration.update().catch(() => undefined);
};
""")
write('src/platform/browser/application-recovery.adapter.ts', """const unregisterServiceWorkers = async (): Promise<void> => {
  if (!('serviceWorker' in navigator)) return;
  const registrations = await navigator.serviceWorker.getRegistrations();
  await Promise.all(registrations.map((registration) => registration.unregister()));
};

const clearApplicationCaches = async (): Promise<void> => {
  if (!('caches' in window)) return;
  const cacheNames = await caches.keys();
  await Promise.all(
    cacheNames
      .filter((cacheName) => cacheName.startsWith('foodorder-v1-'))
      .map((cacheName) => caches.delete(cacheName)),
  );
};

export const recoverApplication = async (): Promise<void> => {
  await Promise.allSettled([
    unregisterServiceWorkers(),
    clearApplicationCaches(),
  ]);
  window.location.reload();
};
""")
replace('src/platform/browser/index.ts', "export { dispatchAppEvent, subscribeToAppEvent } from './app-events.adapter';\n", "export { recoverApplication } from './application-recovery.adapter';\nexport { dispatchAppEvent, subscribeToAppEvent } from './app-events.adapter';\n")
write('public/sw.js', """const CACHE_PREFIX = 'foodorder-v1-shell-';
const VERSION = new URL(self.location.href).searchParams.get('v') || 'unknown';
const CACHE_NAME = `${CACHE_PREFIX}${VERSION}`;
const SHELL_RESOURCES = ['/', '/index.html', '/manifest.webmanifest', '/icon.svg'];

const isHtmlAssetMismatch = (request, response) =>
  request.mode !== 'navigate' &&
  ['script', 'style', 'worker'].includes(request.destination) &&
  (response.headers.get('content-type') || '').includes('text/html');

const cacheSuccessfulResponse = async (request, response) => {
  if (
    !response.ok ||
    isHtmlAssetMismatch(request, response) ||
    new URL(request.url).origin !== self.location.origin
  )
    return;
  const cache = await caches.open(CACHE_NAME);
  await cache.put(request, response.clone());
};

const networkFirstNavigation = async (request) => {
  try {
    const response = await fetch(request);
    if (isHtmlAssetMismatch(request, response)) throw new Error('Invalid asset response.');
    await cacheSuccessfulResponse(request, response);
    return response;
  } catch {
    return (
      (await caches.match(request)) ||
      (await caches.match('/index.html')) ||
      Response.error()
    );
  }
};

const exactResourceFallback = async (request) => {
  try {
    const response = await fetch(request);
    if (isHtmlAssetMismatch(request, response)) throw new Error('Invalid asset response.');
    await cacheSuccessfulResponse(request, response);
    return response;
  } catch {
    const cached = await caches.match(request);
    if (cached) return cached;
    return Response.error();
  }
};

self.addEventListener('install', (event) => {
  event.waitUntil(
    caches.open(CACHE_NAME).then((cache) =>
      Promise.allSettled(SHELL_RESOURCES.map((resource) => cache.add(resource))),
    ),
  );
  self.skipWaiting();
});

self.addEventListener('activate', (event) => {
  event.waitUntil(
    caches.keys().then((cacheNames) =>
      Promise.all(
        cacheNames
          .filter(
            (cacheName) =>
              cacheName.startsWith(CACHE_PREFIX) && cacheName !== CACHE_NAME,
          )
          .map((cacheName) => caches.delete(cacheName)),
      ),
    ),
  );
  self.clients.claim();
});

self.addEventListener('fetch', (event) => {
  if (event.request.method !== 'GET') return;
  event.respondWith(
    event.request.mode === 'navigate'
      ? networkFirstNavigation(event.request)
      : exactResourceFallback(event.request),
  );
});
""")

# App-level recoverable error boundary with owned types/messages/styles.
write('src/app/errors/app-error-boundary.types.ts', """import type { ErrorInfo, ReactNode } from 'react';

export interface AppErrorBoundaryProps {
  children: ReactNode;
}

export interface AppErrorBoundaryState {
  hasError: boolean;
}

export interface AppErrorDetails {
  error: unknown;
  errorInfo: ErrorInfo;
}
""")
write('src/app/errors/app-error-boundary.messages.ts', """export const APP_ERROR_MESSAGES = {
  en: {
    eyebrow: 'Recovery mode',
    title: 'The app could not start correctly',
    description:
      'A cached update or an unexpected startup error interrupted the app. Clear the app cache and reload safely.',
    action: 'Recover and reload',
  },
  ar: {
    eyebrow: 'وضع الاستعادة',
    title: 'تعذر تشغيل التطبيق بشكل صحيح',
    description:
      'أوقف تحديث مخزن مؤقت أو خطأ غير متوقع تشغيل التطبيق. امسح ذاكرة التطبيق وأعد التحميل بأمان.',
    action: 'استعادة وإعادة التحميل',
  },
} as const;
""")
write('src/app/errors/app-error-boundary.component.tsx', """import './app-error-boundary.css';

import { Component } from 'react';

import { getDocumentLanguage, recoverApplication } from '@/platform/browser';

import { APP_ERROR_MESSAGES } from './app-error-boundary.messages';
import type {
  AppErrorBoundaryProps,
  AppErrorBoundaryState,
} from './app-error-boundary.types';

export class AppErrorBoundary extends Component<
  AppErrorBoundaryProps,
  AppErrorBoundaryState
> {
  override state: AppErrorBoundaryState = { hasError: false };

  static getDerivedStateFromError(): AppErrorBoundaryState {
    return { hasError: true };
  }

  override render() {
    if (!this.state.hasError) return this.props.children;

    const locale = getDocumentLanguage().toLowerCase().startsWith('ar')
      ? 'ar'
      : 'en';
    const message = APP_ERROR_MESSAGES[locale];

    return (
      <main className=\"app-error-boundary\" dir={locale === 'ar' ? 'rtl' : 'ltr'}>
        <section className=\"app-error-boundary__card\" role=\"alert\">
          <p className=\"eyebrow\">{message.eyebrow}</p>
          <h1>{message.title}</h1>
          <p>{message.description}</p>
          <button
            type=\"button\"
            className=\"button primary\"
            onClick={() => void recoverApplication()}
          >
            {message.action}
          </button>
        </section>
      </main>
    );
  }
}
""")
write('src/app/errors/app-error-boundary.css', """.app-error-boundary {
  min-height: 100dvh;
  display: grid;
  place-items: center;
  padding: max(1rem, env(safe-area-inset-top)) max(1rem, env(safe-area-inset-right))
    max(1rem, env(safe-area-inset-bottom)) max(1rem, env(safe-area-inset-left));
  background: var(--color-background, #fff7ed);
  color: var(--color-text, #1f2937);
}

.app-error-boundary__card {
  width: min(100%, 38rem);
  display: grid;
  gap: 1rem;
  padding: clamp(1.25rem, 4vw, 2rem);
  border: 1px solid color-mix(in srgb, currentColor 16%, transparent);
  border-radius: 1.25rem;
  background: var(--color-surface, #ffffff);
  box-shadow: 0 1.25rem 3rem rgb(15 23 42 / 12%);
}

.app-error-boundary__card h1,
.app-error-boundary__card p {
  margin: 0;
}
""")
replace('src/app/index.ts', "export { AppRoutes } from './router/app.routes';\n", "export { AppErrorBoundary } from './errors/app-error-boundary.component';\nexport { AppRoutes } from './router/app.routes';\n")
