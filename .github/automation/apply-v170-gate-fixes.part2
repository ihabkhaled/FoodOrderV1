# Direct component test for the recovery boundary.
write('tests/components/AppErrorBoundary.test.tsx', """import { fireEvent, render, screen } from '@testing-library/react';
import { beforeEach, describe, expect, it, vi } from 'vitest';

const recoverApplication = vi.fn<() => Promise<void>>().mockResolvedValue();

vi.mock('@/platform/browser', async (importOriginal) => {
  const original = await importOriginal<typeof import('@/platform/browser')>();
  return {
    ...original,
    getDocumentLanguage: () => 'en',
    recoverApplication,
  };
});

import { AppErrorBoundary } from '@/app';

function BrokenChild(): never {
  throw new Error('startup failed');
}

describe('AppErrorBoundary', () => {
  beforeEach(() => {
    recoverApplication.mockClear();
  });

  it('renders a recoverable startup state and invokes cache recovery', () => {
    render(
      <AppErrorBoundary>
        <BrokenChild />
      </AppErrorBoundary>,
    );

    expect(
      screen.getByRole('heading', { name: 'The app could not start correctly' }),
    ).toBeInTheDocument();

    fireEvent.click(screen.getByRole('button', { name: 'Recover and reload' }));
    expect(recoverApplication).toHaveBeenCalledOnce();
  });
});
""")

