rules_version = '2';

// Authorization for FoodOrderV1 schema v4.
// Client role checks are UX only; Security Rules and trusted Functions are enforcement.
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function owns(userId) { return signedIn() && request.auth.uid == userId; }

    // Exact-email discovery is performed only by trusted callable Functions.
    // Clients may publish their own directory entry but can never read the directory.
    match /publicProfiles/{userId} {
      function validPublicProfile() {
        return owns(userId)
          && request.resource.data.userId == userId
          && request.resource.data.email == request.auth.token.email
          && request.resource.data.emailNormalized == request.auth.token.email
          && request.resource.data.displayName is string;
      }
      allow read: if false;
      allow create, update: if validPublicProfile();
      allow delete: if owns(userId);
    }

    match /users/{userId} {
      function validProfile() {
        return request.resource.data.id == userId
          && request.resource.data.email == request.auth.token.email
          && request.resource.data.fullName is string
          && request.resource.data.locale in ['en', 'ar']
          && request.resource.data.theme in ['system', 'light', 'dark'];
      }

      function validPersonalPricingPolicy(pricing) {
        return pricing is map
          && pricing.vatBasisPoints is int
          && pricing.vatBasisPoints >= 0
          && pricing.vatBasisPoints <= 10000
          && pricing.serviceBasisPoints is int
          && pricing.serviceBasisPoints >= 0
          && pricing.serviceBasisPoints <= 10000
          && pricing.deliveryMinor is int
          && pricing.deliveryMinor >= 0
          && pricing.vatAllocation in ['equal', 'proportional']
          && pricing.serviceAllocation in ['equal', 'proportional']
          && pricing.deliveryAllocation in ['equal', 'proportional'];
      }

      function validPersonalOrderReceipt() {
        let receipt = request.resource.data.get('groupReceipt', null);
        return receipt == null
          || (request.resource.data.get('participants', null) == null
            && receipt is map
            && receipt.currency == request.resource.data.currency
            && receipt.itemSubtotalMinor is int
            && receipt.itemSubtotalMinor >= 0
            && receipt.vatMinor is int
            && receipt.vatMinor >= 0
            && receipt.serviceMinor is int
            && receipt.serviceMinor >= 0
            && receipt.deliveryMinor is int
            && receipt.deliveryMinor >= 0
            && receipt.grandTotalMinor is int
            && receipt.grandTotalMinor
              == receipt.itemSubtotalMinor
                + receipt.vatMinor
                + receipt.serviceMinor
                + receipt.deliveryMinor
            && receipt.bucketRevision is int
            && receipt.bucketRevision >= 1
            && validPersonalPricingPolicy(receipt.pricingPolicy)
            && receipt.participantReceipts is list
            && receipt.participantReceipts.size() == 1
            && receipt.participantReceipts[0].userId == userId
            && receipt.items is list);
      }

      allow read: if owns(userId);
      allow create, update: if owns(userId) && validProfile();
      allow delete: if owns(userId);

      match /orders/{orderId} {
        allow read, delete: if owns(userId);
        // Personal orders may snapshot their bucket charges on the client. Multi-person
        // group receipt snapshots remain trusted Function writes and bypass client Rules.
        allow create, update: if owns(userId)
          && request.resource.data.userId == userId
          && request.resource.data.id == orderId
          && request.resource.data.status in ['draft', 'placed', 'completed', 'cancelled']
          && request.resource.data.lines is list
          && request.resource.data.lines.size() > 0
          && request.resource.data.total is number
          && request.resource.data.total >= 0
          && validPersonalOrderReceipt();
      }

      match /bucketMemberships/{bucketId} {
        allow read, write: if owns(userId);
      }

      // Social mirrors are readable only by their owner. All mutations are performed
      // by callable Functions so clients cannot forge requests, friendships, or groups.
      match /friendRequests/{requestId} {
        allow read: if owns(userId);
        allow write: if false;
      }
      match /friends/{friendId} {
        allow read: if owns(userId);
        allow write: if false;
      }
      match /groupInvitations/{groupId} {
        allow read: if owns(userId);
        allow write: if false;
      }
      match /groupMemberships/{groupId} {
        allow read: if owns(userId);
        allow write: if false;
      }

      match /buckets/{bucketId} {
        allow read, delete: if owns(userId);
        allow create, update: if false;
      }
    }

    // Friend groups and membership changes are callable-only. Overview data is returned
    // through a trusted function that filters it to the authenticated user.
    match /friendGroups/{groupId} {
      allow read, write: if false;
      match /members/{memberId} {
        allow read, write: if false;
      }
      match /bucketGrants/{bucketId} {
        allow read, write: if false;
      }
    }

    match /buckets/{bucketId} {
      function bucket() {
        return get(/databases/$(database)/documents/buckets/$(bucketId)).data;
      }
      function isBucketOwner() {
        return signedIn() && bucket().ownerId == request.auth.uid;
      }
      function memberPath(uid) {
        return /databases/$(database)/documents/buckets/$(bucketId)/members/$(uid);
      }
      function member() { return get(memberPath(request.auth.uid)).data; }
      function isActiveMember() {
        return signedIn()
          && exists(memberPath(request.auth.uid))
          && member().status == 'active';
      }
      function activeRole() { return member().role; }
      function canView() { return isBucketOwner() || isActiveMember(); }
      function canContribute() {
        return isActiveMember()
          && activeRole() in ['owner', 'editor', 'contributor'];
      }
      function canEditStructure() {
        return isActiveMember() && activeRole() in ['owner', 'editor'];
      }
      function stateOf(data) { return data.get('orderState', 'open'); }
      function bucketIsOpen() { return stateOf(bucket()) == 'open'; }
      function requestBucketIsOpen() {
        return stateOf(request.resource.data) == 'open';
      }
      function validPricingPolicy() {
        let pricing = request.resource.data.pricingPolicy;
        return pricing is map
          && pricing.vatBasisPoints is int
          && pricing.vatBasisPoints >= 0
          && pricing.vatBasisPoints <= 10000
          && pricing.serviceBasisPoints is int
          && pricing.serviceBasisPoints >= 0
          && pricing.serviceBasisPoints <= 10000
          && pricing.deliveryMinor is int
          && pricing.deliveryMinor >= 0
          && pricing.vatAllocation in ['equal', 'proportional']
          && pricing.serviceAllocation in ['equal', 'proportional']
          && pricing.deliveryAllocation in ['equal', 'proportional'];
      }
      function validV3Fields() {
        return request.resource.data.schemaVersion == 3
          && request.resource.data.orderState in ['open', 'frozen', 'ordering', 'ordered']
          && request.resource.data.customItemMode in ['disabled', 'proposal', 'direct']
          && (request.resource.data.frozenAt is string
            || request.resource.data.frozenAt == null)
          && (request.resource.data.frozenBy is string
            || request.resource.data.frozenBy == null)
          && validPricingPolicy();
      }
      function validBucketShape() {
        return request.resource.data.id == bucketId
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 60
          && request.resource.data.visibility in ['private', 'shared']
          && request.resource.data.status == 'active'
          && request.resource.data.schemaVersion in [2, 3]
          && (request.resource.data.schemaVersion == 2 || validV3Fields())
          && request.resource.data.revision is int
          && request.resource.data.revision >= 1
          && request.resource.data.items is list
          && request.resource.data.items.size() > 0
          && request.resource.data.items.size() <= 50
          && request.resource.data.aggregate is map;
      }
      function immutableBucketIdentity() {
        return request.resource.data.ownerId == resource.data.ownerId
          && request.resource.data.createdAt == resource.data.createdAt;
      }
      function nextRevision() {
        return request.resource.data.revision == resource.data.revision + 1;
      }
      function contributorAggregateUpdate() {
        return canContribute()
          && bucketIsOpen()
          && requestBucketIsOpen()
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['aggregate', 'revision', 'updatedAt']);
      }
      function editorStructureUpdate() {
        return canEditStructure()
          && !isBucketOwner()
          && bucketIsOpen()
          && requestBucketIsOpen()
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly([
              'title',
              'description',
              'currency',
              'pricingPolicy',
              'items',
              'aggregate',
              'revision',
              'updatedAt'
            ]);
      }

      allow get: if canView();
      allow list: if signedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && validBucketShape();
      allow update: if validBucketShape()
        && immutableBucketIdentity()
        && nextRevision()
        && (
          isBucketOwner()
          || editorStructureUpdate()
          || contributorAggregateUpdate()
        );
      allow delete: if isBucketOwner();

      match /members/{memberId} {
        function inviteAfter() {
          return getAfter(/databases/$(database)/documents/buckets/$(bucketId)/invites/$(request.resource.data.inviteId)).data;
        }
        function inviteBefore() {
          return get(/databases/$(database)/documents/buckets/$(bucketId)/invites/$(request.resource.data.inviteId)).data;
        }
        function validSelfJoin() {
          return owns(memberId)
            && request.resource.data.userId == memberId
            && request.resource.data.status == 'active'
            && request.resource.data.inviteId is string
            && inviteBefore().status == 'pending'
            && inviteBefore().expiresAtMillis > request.time.toMillis()
            && inviteAfter().status == 'accepted'
            && inviteAfter().acceptedBy == request.auth.uid
            && request.resource.data.role == inviteAfter().role
            && request.resource.data.role in ['editor', 'contributor', 'viewer'];
        }
        function ownerSelfDoc() {
          return owns(memberId)
            && request.resource.data.userId == memberId
            && request.resource.data.role == 'owner'
            && request.resource.data.status == 'active'
            && getAfter(/databases/$(database)/documents/buckets/$(bucketId)).data.ownerId == memberId;
        }
        function validManagedMember() {
          return request.resource.data.userId == resource.data.userId
            && request.resource.data.role in ['editor', 'contributor', 'viewer']
            && request.resource.data.status in ['active', 'revoked']
            && request.resource.data.get('canCreateCustomItems', false) is bool
            && request.resource.data.get('canSetCustomItemPrice', false) is bool
            && (!request.resource.data.get('canSetCustomItemPrice', false)
              || request.resource.data.get('canCreateCustomItems', false));
        }

        // A signed-in invitee may read only their own membership document so a
        // transaction can determine whether they previously joined or were revoked.
        // Listing members remains restricted to existing bucket viewers.
        allow get: if canView() || owns(memberId);
        allow list: if canView();
        allow create: if ownerSelfDoc() || validSelfJoin();
        allow update: if
          ownerSelfDoc()
          || (isBucketOwner() && resource.data.role != 'owner' && validManagedMember())
          || (owns(memberId)
            && resource.data.role != 'owner'
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'updatedAt'])
            && request.resource.data.status == 'left')
          || (resource.data.status in ['revoked', 'left'] && validSelfJoin());
        allow delete: if isBucketOwner();
      }

      match /invites/{inviteId} {
        allow get: if signedIn();
        allow list: if isBucketOwner();
        allow create: if isBucketOwner()
          && request.resource.data.id == inviteId
          && request.resource.data.bucketId == bucketId
          && request.resource.data.status == 'pending'
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.role in ['editor', 'contributor', 'viewer']
          && request.resource.data.expiresAtMillis is number;
        allow update: if
          (isBucketOwner()
            && resource.data.status == 'pending'
            && request.resource.data.status == 'revoked')
          || (signedIn()
            && resource.data.status == 'pending'
            && resource.data.expiresAtMillis > request.time.toMillis()
            && request.resource.data.status == 'accepted'
            && request.resource.data.acceptedBy == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'acceptedBy', 'acceptedAt']));
        allow delete: if isBucketOwner();
      }

      match /contributions/{contributorId} {
        allow read: if canView();
        allow create, update: if owns(contributorId)
          && canContribute()
          && bucketIsOpen()
          && request.resource.data.userId == contributorId
          && request.resource.data.bucketId == bucketId
          && request.resource.data.quantities is map
          && request.resource.data.revision is int
          && request.resource.data.revision >= 1;
        allow delete: if isBucketOwner();
      }

      match /mutations/{mutationId} {
        allow get: if canView();
        allow list: if isBucketOwner();
        allow create: if canContribute()
          && bucketIsOpen()
          && request.resource.data.id == mutationId
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.bucketId == bucketId;
        allow update: if false;
        allow delete: if isBucketOwner();
      }

      // Trusted Functions own financial finalization and custom-item mutations.
      match /orderMutations/{mutationId} {
        allow read: if isBucketOwner();
        allow write: if false;
      }

      // Direct-user and group grants are independent trusted sources. Clients cannot
      // forge or remove them; owners read the effective grant list through a callable.
      match /accessGrants/{grantId} {
        allow read, write: if false;
      }

      match /activity/{eventId} {
        function isActiveMemberAfter() {
          return existsAfter(memberPath(request.auth.uid))
            && getAfter(memberPath(request.auth.uid)).data.status == 'active';
        }
        allow read: if canView();
        allow create: if (canView() || isActiveMemberAfter())
          && request.resource.data.actorId == request.auth.uid
          && request.resource.data.bucketId == bucketId;
        allow update: if false;
        allow delete: if isBucketOwner();
      }
    }
  }
}
